# ============================================================
# X Feed Intel — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Anthropic API (Required) ---
# Used for Haiku classification and Opus topic matching.
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- X (Twitter) API — OAuth 1.0a (Required for timeline collection) ---
# Obtain from https://developer.x.com/en/portal/dashboard
# Consumer key/secret: from your App settings (Keys and Tokens tab).
X_CONSUMER_KEY=your-x-api-key
X_CONSUMER_SECRET=your-x-api-secret
# Access token/secret: generated for your own account (Read permission only needed).
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret
# Bearer token: found on the same Keys and Tokens page.
X_BEARER_TOKEN=your-bearer-token
# User ID: your numeric X account ID (find at https://tweeterid.com or via the X API).
# Required — without this, timeline fetching will fail at startup validation.
X_USER_ID=your-numeric-x-user-id

# Set to 1 to enable X timeline collection. Defaults to 0 (dashboard-only mode).
X_COLLECTION_ENABLED=0

# --- Gmail SMTP (Optional — for email notifications) ---
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# --- Dashboard ---
# Optional fallback list of display names for team-vote UI labels.
VOTER_NAMES=Admin,User1,User2
# Flask session encryption key. Generate a strong random value:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-string
# Set to 1 when the dashboard is served over HTTPS.
# SESSION_COOKIE_SECURE=1

# --- Transcription Integration (Optional, disabled by default) ---
# Enables webhook callbacks from a co-deployed video transcription pipeline.
# Set to 1 only if you are running x-feed-intel alongside that pipeline.
TRANSCRIPTION_INTEGRATION_ENABLED=0
TRANSCRIPTION_INTEGRATION_TOKEN=your-integration-token
TRANSCRIPTION_CALLBACK_URL=http://127.0.0.1:5050/api/integrations/transcription-events

# --- Logging (Optional) ---
# Defaults to ./logs relative to the repo root.
# LOG_DIR=./logs
